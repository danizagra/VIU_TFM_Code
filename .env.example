# === LLM Provider ===
# Options: "lm_studio", "deepseek", "openai"
LLM_PROVIDER=lm_studio

# === LM Studio (Local) ===
LM_STUDIO_BASE_URL=http://127.0.0.1/v1
LM_STUDIO_MODEL=gpt-oss-20b

# === DeepSeek (Cheap Fallback) ===
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_MODEL=deepseek-chat

# === OpenAI (Optional, for maximum quality) ===
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# === News APIs ===
NEWSAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GNEWS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Database ===
DATABASE_URL=postgresql://daniel:@localhost:5432/tfm_db

# === Agent Configuration ===
DEFAULT_LANGUAGE=es
DEFAULT_REGION=co
MAX_ARTICLES_PER_FETCH=100
SIMILARITY_THRESHOLD=0.65
DUPLICATE_THRESHOLD=0.95

# === Embeddings (LM Studio preferred for better RAG results) ===
# Use LM Studio's embedding API instead of local SentenceTransformers
USE_LM_STUDIO_EMBEDDINGS=true
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
EMBEDDING_DIMENSION=768

# === LLM Generation ===
LLM_TEMPERATURE=0.5
LLM_MAX_TOKENS=1000

# === Telegram Bot ===
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_API_BASE_URL=http://localhost:8000
